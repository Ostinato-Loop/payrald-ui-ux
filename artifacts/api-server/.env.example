PORT=8080
NODE_ENV=development
DATABASE_URL=postgres://user:password@host:5432/payrald

# Squad Co — https://squadco.com
# Set SQUAD_ENV=production to use live endpoints
SQUAD_ENV=sandbox
SQUADCO_SECRET_KEY=sandbox_sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SQUADCO_PUBLIC_KEY=sandbox_pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Wema Bank ALAT for Business — https://developer.wemabank.com
WEMA_BANK_BASE_URL=https://apigateway.wemabank.com
WEMA_BANK_API_KEY=your_wema_api_key
WEMA_BANK_SECRET_KEY=your_wema_secret_key

# ALIA Resolution Engine — internal RALD service
ALIA_RESOLUTION_URL=https://resolution.alia.rald.cloud
ALIA_INTERNAL_API_KEY=your_alia_internal_api_key

# PayRald internal config
PAYRALD_BANK_CODE=035
